# Notion API Integration Token
# 获取方式：https://www.notion.so/my-integrations → New integration → 复制 Internal Integration Token
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 工作流库 Database ID
# 获取方式：打开 Notion 数据库页面 → 复制 URL 中 notion.so/后面、?v= 前面的32位字符串
WORKFLOW_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 笔记库 Database ID
NOTES_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
